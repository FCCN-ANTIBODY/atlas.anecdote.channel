---
# Build-time manifest: the only thing the build does with the registry is emit
# this small, cacheable JSON list. The runtime client (assets/atlas.js) reads it
# and fetches each pile's map per-slice in the browser. No network IO at build.
layout: null
permalink: /piles.json
---
{%- assign piles = site.data.piles -%}
[
{%- for pile in piles -%}
  {
    "id": {{ pile.id | jsonify }},
    "name": {{ pile.name | jsonify }},
    "url": {{ pile.url | jsonify }},
    "fixture": {{ pile.fixture | jsonify }},
    "level": {{ pile.level | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
