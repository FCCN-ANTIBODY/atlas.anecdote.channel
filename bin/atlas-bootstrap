#!/usr/bin/env bash
# One-time Atlas operator setup for the peer-discovery signer. Generates the single key
# the peer-registration gesture needs (register-peer.yml / bin/register-atlas), stores its
# PRIVATE half as the repo secret ATLAS_SIGNER_KEY, publishes the PUBLIC half for peer
# Atlases to pin, and commits that public material.
#
# There is no GitHub App: this is an ordinary SSH signing key an operator holds. It is the
# Atlas analogue of a Tell's delivery signer (keys/tell.fpr), one tier up: a Tell signs its
# registration WITH an Atlas; an Atlas signs its registration as a peer OF another Atlas.
# Re-running refuses to clobber an existing committed signer unless --force (a new signer
# means every peer that pinned the old fingerprint must re-pin — see keys/README.md).
#
#   bin/atlas-bootstrap [--force] [--no-secrets] [--no-commit]
#     --force        rotate even if keys/atlas.pub already exists (peers must re-pin)
#     --no-secrets   skip `gh secret set` (just print what to set, for manual/CI setup)
#     --no-commit    generate + publish locally but don't git commit/push
#
# Requires: ssh-keygen, git. `gh` only when actually setting the secret.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
repo="$(cd "$here/.." && pwd)"
cd "$repo"

force=0; do_secrets=1; do_commit=1
while [ $# -gt 0 ]; do
  case "$1" in
    --force) force=1; shift;;
    --no-secrets) do_secrets=0; shift;;
    --no-commit) do_commit=0; shift;;
    *) echo "atlas-bootstrap: unknown arg: $1" >&2; exit 1;;
  esac
done

for t in ssh-keygen git; do
  command -v "$t" >/dev/null 2>&1 || { echo "atlas-bootstrap: missing required tool: $t" >&2; exit 1; }
done

if [ -f keys/atlas.pub ] && [ "$force" != 1 ]; then
  echo "atlas-bootstrap: keys/atlas.pub already exists." >&2
  echo "  Atlas is already provisioned. Re-running rotates the peer-signer, which forces" >&2
  echo "  EVERY peer that pinned the old fingerprint to re-pin. Pass --force to rotate." >&2
  exit 1
fi

umask 077
tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT

echo "==> generating Atlas peer-signer (ssh ed25519)"
ssh-keygen -t ed25519 -N '' -C atlas-peer-signer -f "$tmp/atlas-signer" >/dev/null

echo "==> publishing PUBLIC signer material (keys/atlas.{pub,signers,fpr})"
bin/publish-signer "$tmp/atlas-signer.pub" >/dev/null
fpr="$(cat keys/atlas.fpr)"

if [ "$do_secrets" = 1 ] && command -v gh >/dev/null 2>&1; then
  echo "==> storing the PRIVATE half as the repo secret ATLAS_SIGNER_KEY via gh"
  gh secret set ATLAS_SIGNER_KEY < "$tmp/atlas-signer"
  echo "    set ATLAS_SIGNER_KEY"
else
  echo "==> NOT setting the secret here. Set it yourself (value printed ONCE below):"
  echo "    gh secret set ATLAS_SIGNER_KEY   # paste the private signer key"
  echo "----- ATLAS_SIGNER_KEY -----"; cat "$tmp/atlas-signer"
  echo "----------------------------"
fi

if [ "$do_commit" = 1 ]; then
  echo "==> committing public signer material"
  git add keys/atlas.pub keys/atlas.signers keys/atlas.fpr
  if git diff --cached --quiet; then
    echo "    (no change to commit)"
  else
    git commit -q -m "atlas: publish peer signer (public material only)"
    echo "    committed. Push when ready: git push"
  fi
fi

# The private key file lives only under $tmp (umask 077) and is removed on exit.
echo
echo "Done. Atlas peer-signer fingerprint:"
echo "    $fpr"
echo "A peer pins this (its _data/atlases.yml signer:) and confirms it out-of-band / IRL."
echo "register-peer.yml can now open signed peer-registration PRs."
