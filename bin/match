#!/usr/bin/env bash
# The matchmaker — the MIXED MODEL (civic-node#91). For each need Atlas carries
# (_data/needs.yml), find candidate piles in the same scope from BOTH registries it holds:
# the Tell-fronted piles it indexes (_data/piles.yml) and the hearsay piles it keeps itself
# (_data/hearsay-piles.yml — shadow questions are exactly the kind that should be found when
# searched; a hearsay candidate rides with provisioner "self" so the judge sees what it is
# matching into, and is addressed through this Atlas since it has no Tell). The fit check
# is the EJECTED seam (mirrors data-pile's bin/judge): set ATLAS_MATCH_CMD to an agent or a
# human that reads the candidate's CONSTITUTION/questions and judges; the default is honest
# (`needs-judgment`), so nothing auto-matches without a real judge. Emits matches.json
# (accepted matches only), which Atlas publishes at /matches.json; the asker PULLS it. Atlas
# never writes into an asker — routing a match home is the asker's own pull + re-issue.
#
#   bin/match
# Env: ATLAS_MATCH_CMD  command reading {need,candidate} JSON on stdin -> {verdict,reason}
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
repo="$(cd "$here/.." && pwd)"
# Inputs/outputs default to this repo's own registry, so running bin/match bare is
# unchanged. The ATLAS_* overrides let a host workspace point the same matchmaker at
# its OWN needs/piles/tells (see .github/actions/match) — the library aspect.
needs_file="${ATLAS_NEEDS:-$repo/_data/needs.yml}"
piles_file="${ATLAS_PILES:-$repo/_data/piles.yml}"
hearsay_file="${ATLAS_HEARSAY:-$repo/_data/hearsay-piles.yml}"
tells_file="${ATLAS_TELLS:-$repo/_data/tells.yml}"
config_file="${ATLAS_CONFIG:-$repo/_config.yml}"
out_file="${ATLAS_OUT:-$repo/matches.json}"
y2j() { ruby -ryaml -rjson -e 'puts JSON.generate(YAML.load_file(ARGV[0]) || [])' "$1"; }

needs="$(y2j "$needs_file")"
piles="$(y2j "$piles_file")"
hearsay="[]"; [ -f "$hearsay_file" ] && hearsay="$(y2j "$hearsay_file")"
tells="$(y2j "$tells_file")"
atlas_url="$(ruby -ryaml -e 'c=YAML.load_file(ARGV[0]) rescue {}; puts((c||{})["url"].to_s)' "$config_file" 2>/dev/null || true)"
atlas_url="${atlas_url:-https://atlas.anecdote.channel}"
match_cmd="${ATLAS_MATCH_CMD:-}"

matches="[]"
nn="$(jq 'length' <<<"$needs")"; i=0
while [ "$i" -lt "$nn" ]; do
  need="$(jq -c ".[$i]" <<<"$needs")"; i=$((i+1))
  nscope="$(jq -r '.scope // ""' <<<"$need")"
  # Prefilter: candidate piles Atlas indexes in the same scope — the Tell-fronted registry
  # UNIONED with the hearsay keyring (mixed model; a keyring row is marked self-kept).
  # only LIVE doors match — a retired keep's question stays findable in archived/, but a match
  # is an invitation to route answers into a mailbox, and a retired mailbox takes none (a fresh
  # drop rises into a NEW tank instead — the stone skips).
  cands="$(jq -c --arg s "$nscope" --argjson h "$hearsay" \
    '[.[]|select(.scope==$s)] + [$h[]|select(.scope==$s and ((.status // "live")=="live"))|{id, scope, hearsay:true, repo_url:(.repo_url // ""), q:((.pile // "?") + "/" + (.poll // "?"))}]' <<<"$piles")"
  turl="$(jq -r --arg s "$nscope" 'map(select(.scope==$s))|.[0].url // ""' <<<"$tells")"
  cn="$(jq 'length' <<<"$cands")"; j=0
  while [ "$j" -lt "$cn" ]; do
    pid="$(jq -r ".[$j].id" <<<"$cands")"
    hflag="$(jq -r ".[$j].hearsay // false" <<<"$cands")"
    hrepo="$(jq -r ".[$j].repo_url // \"\"" <<<"$cands")"
    hq="$(jq -r ".[$j].q // \"\"" <<<"$cands")"; j=$((j+1))
    if [ "$hflag" = "true" ]; then
      # a hearsay DOOR has no Tell: addressed through this Atlas, saying who keeps it and which
      # question it routes (many doors may share one tank; the question keeps them distinct).
      cand="$(jq -nc --arg a "$atlas_url" --arg p "$pid" --arg r "$hrepo" --arg q "$hq" \
        '{atlas_url:$a,tell_url:$a,pile_id:$p,provisioner:"self",repo_url:$r,question:$q}')"
    else
      cand="$(jq -nc --arg a "$atlas_url" --arg t "$turl" --arg p "$pid" '{atlas_url:$a,tell_url:$t,pile_id:$p}')"
    fi
    if [ -n "$match_cmd" ]; then
      v="$(jq -nc --argjson need "$need" --argjson candidate "$cand" '{need:$need,candidate:$candidate}' | "$match_cmd")"
      verdict="$(jq -r '.verdict // "needs-judgment"' <<<"$v")"
      reason="$(jq -r '.reason // ""' <<<"$v")"
    else
      verdict="needs-judgment"; reason="constitutional fit needs an agent/human (set ATLAS_MATCH_CMD)"
    fi
    [ "$verdict" = accept ] || continue
    creq="$(jq -r 'if (.terms // "")=="" then true else false end' <<<"$need")"
    matches="$(jq -c --argjson need "$need" --argjson cand "$cand" --arg v "$verdict" --arg r "$reason" --argjson creq "$creq" \
      '. + [{need_id:$need.id, asker_repo:$need.asker_repo, candidate:$cand, verdict:$v, reason:$r, consent_required:$creq}]' <<<"$matches")"
  done
done

jq . <<<"$matches" > "$out_file"
echo "match: wrote matches.json ($(jq length <<<"$matches") accepted match(es))" >&2
