#!/usr/bin/env bash
# Publish Atlas's PUBLIC delivery-signer material so a pile owner can register it
# by hand (and confirm it out-of-band / IRL). This is the whole trust handoff —
# there is no GitHub App. Atlas signs each manifest head with an ordinary SSH key
# (ssh-keygen -Y sign); a pile records the matching public key + fingerprint and
# bin/verify checks every delivery against it.
#
#   bin/publish-signer PUBKEY        # e.g. keys/atlas-signer.pub, or ~/.ssh/id_ed25519.pub
#
# Emits, into keys/:
#   keys/atlas.signers   one allowed-signers line: `atlas <type> <base64> ...`
#                        (copy this verbatim into a pile's keys/atlas.signers)
#   keys/atlas.pub       the raw public key
#   keys/atlas.fpr       the SHA256:… fingerprint a pile pins in pile.yml `signer:`
#
# The PRIVATE key is never handled here. In CI it lives only as the secret
# ATLAS_SIGNER_KEY, materialized to a temp file for the one ssh-keygen -Y sign call.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
keys="$here/../keys"; mkdir -p "$keys"

pub="${1:-}"
[ -n "$pub" ] && [ -f "$pub" ] || { echo "usage: bin/publish-signer PATH/TO/signer.pub" >&2; exit 1; }

cp "$pub" "$keys/atlas.pub"
# allowed-signers: <principal> <key>. Principal "atlas" matches verify's -I <source>.
printf 'atlas %s\n' "$(cat "$pub")" > "$keys/atlas.signers"
fpr="$(ssh-keygen -lf "$pub" | awk '{print $2}')"
printf '%s\n' "$fpr" > "$keys/atlas.fpr"

echo "Published Atlas signer:"
echo "  fingerprint : $fpr   (pin this in a pile's pile.yml  signer:)"
echo "  allowed-line: $(cat "$keys/atlas.signers")"
echo "  -> a pile copies keys/atlas.signers into its own keys/atlas.signers"
