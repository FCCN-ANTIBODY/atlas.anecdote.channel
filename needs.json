---
# Build-time manifest: the public "what's hanging" list, rendered from _data/needs.yml.
# A tip line (journalists: what's going unanswered in your area) and a board (networking).
# Queryable client-side by scope/topic. No network IO at build.
layout: null
permalink: /needs.json
---
{%- assign needs = site.data.needs -%}
[
{%- for need in needs -%}
  {
    "id": {{ need.id | jsonify }},
    "asker_repo": {{ need.asker_repo | jsonify }},
    "scope": {{ need.scope | jsonify }},
    "topic": {{ need.topic | jsonify }},
    "terms": {{ need.terms | jsonify }},
    "need_url": {{ need.need_url | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
